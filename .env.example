# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=basedbench/5.0.0

# LLM
OPENAI_API_KEY=
# Required if JUDGE_MODELS (or a predict target) includes a claude-* model.
ANTHROPIC_API_KEY=
# Required if JUDGE_MODELS includes an OpenRouter-hosted model like z-ai/glm-5.2.
OPENROUTER_API_KEY=

# Models (defaults shown — text-only inner-loop calls, modern cheap tier)
CONSENSUS_MODEL=gpt-5.4-mini
# Judge ensemble: every prediction is scored by each model (JSON list).
JUDGE_MODELS=["gpt-5.4-mini", "claude-sonnet-4-6", "z-ai/glm-5.2"]

# Quality thresholds (defaults shown)
MIN_AGREEING_COMMENTS=3
MIN_AVG_COMMENT_SCORE=10.0
MIN_COMMENT_SCORE=5
MAX_COMMENTS_FOR_CONSENSUS=10

# HuggingFace (optional, for push command)
HF_TOKEN=
HF_DATASET_REPO=
